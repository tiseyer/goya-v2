# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth (configure in Supabase Dashboard > Auth > Providers > Google)
# https://supabase.com/docs/guides/auth/social-login/auth-google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple OAuth (configure in Supabase Dashboard > Auth > Providers > Apple)
# https://supabase.com/docs/guides/auth/social-login/auth-apple
APPLE_CLIENT_ID=your-apple-service-id
APPLE_CLIENT_SECRET=your-apple-client-secret

# Secrets Encryption (required for Third Party Keys feature)
# Generate with: openssl rand -base64 32
SECRETS_MASTER_KEY=your-secrets-master-key

# Health Monitoring (required for /api/monitor endpoint)
# Generate with: openssl rand -hex 32
MONITOR_SECRET=
# Email to receive health alerts (defaults to till@seyer-marketing.de)
MONITOR_ALERT_EMAIL=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_SCHOOL_ANNUAL_PRICE_ID=price_...
STRIPE_SCHOOL_SIGNUP_PRICE_ID=price_...

# Vercel (required for Admin Dashboard — Analytics + Deployments sections)
# Get from: https://vercel.com/account/tokens (create a new token)
VERCEL_ACCESS_TOKEN=
# Get from: Vercel Dashboard > Project > Settings > General > Project ID
VERCEL_PROJECT_ID=
